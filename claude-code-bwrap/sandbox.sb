(version 1)

;; Allow everything by default — Claude Code needs broad access
;; for builds, tests, network (API), process execution, etc.
(allow default)

;; Protect .git directories from writes.
;; This prevents the AI agent from rewriting git history.
;; The regex matches any path containing /.git or /.git/...
(deny file-write* (regex #"/\.git(/|$)"))
