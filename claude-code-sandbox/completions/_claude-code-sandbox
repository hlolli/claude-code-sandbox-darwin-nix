#compdef claude-code-sandbox

# Zsh completions for claude-code-sandbox
# Before -- complete directories; after -- args are passed to claude.
_claude-code-sandbox() {
    local i past_separator=0
    for (( i=2; i < CURRENT; i++ )); do
        if [[ "${words[i]}" == "--" ]]; then
            past_separator=1
            break
        fi
    done
    if (( past_separator )); then
        _message 'claude arguments'
    else
        _arguments \
            '(-)--[pass remaining arguments to claude]' \
            '*:project directory:_directories'
    fi
}

_claude-code-sandbox "$@"
